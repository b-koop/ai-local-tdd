{
  "name": "@ai-local/tdd",
  "version": "0.2.0",
  "description": "Pi package that adds the /tdd ticket-driven TDD orchestration command.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "forge",
    "tdd"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nivoset/the-forge.git"
  },
  "bugs": {
    "url": "https://github.com/b-koop/the-forge/issues"
  },
  "homepage": "https://github.com/b-koop/the-forge#readme",
  "pi": {
    "extensions": [
      "./dist/extensions/forge.js",
      "./dist/extensions/ticket-master.js"
    ]
  },
  "files": [
    "agents/",
    "dist/",
    "docs/",
    "features/",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "dependencies": {
    "smart-model-run": "0.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^25.9.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm build && node --test test/*.test.mjs",
    "prepack": "pnpm build",
    "generate:forge-settings": "node --experimental-strip-types scripts/write-forge-settings-sample.mjs"
  }
}
